#!/bin/sh

platform=$(uname -s)

if [ "$platform" = "Linux" ]; then
	alias ll="ls -Fal --color"
	alias ls="ls -F --color"
elif [ "$platform" = "Darwin" ]; then
	alias ll="ls -GFal"
	alias ls="ls -GF"
fi
alias ssh="ssh -A"
alias less="less -X"
alias tig="tig -1000"

umask 022

unset SSH_AUTH_SOCK
unset SSH_AGENT_PID
SSH_AGENT_ENV="$HOME/.ssh/agent-env"
if [ -f "$SSH_AGENT_ENV" ]; then
    . "$SSH_AGENT_ENV" > /dev/null
fi

if [ -z "$SSH_AGENT_PID" ] || ! kill -0 "$SSH_AGENT_PID" 2>/dev/null || [ ! -S "$SSH_AUTH_SOCK" ]; then
	(umask 066; ssh-agent > "$SSH_AGENT_ENV")
    . "$SSH_AGENT_ENV" > /dev/null
    ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/ssh_auth_sock"
fi
export SSH_AUTH_SOCK="$HOME/.ssh/ssh_auth_sock"

export LS_COLORS="no=00:fi=00:di=01;34:ln=00;36:pi=40;33:so=00;35:bd=40;33;01:cd=40;33;01:or=01;05;37;41:mi=01;05;37;41:ex=00;32:*.sh=00;32:*.tar=00;31:*.tgz=00;31:*.zip=00;31:*.gz=00;31:*.bz2=00;31:*.bz=00;31:"
PS1="\[\033[1;32m\]\H\[\033[0m\]"
PS1="$PS1 \[\033[1;34m\]\W\[\033[0m\]"
PS1="$PS1 \[\033[1;31m\]-\u- (=^_^=)\[\033[0m\] "
export PS1
export LSCOLORS=ExFxBxDxCxegedabagacad

rssh() {
	host="$1"
	cmd="$2"

	while true;
	do
		ssh -t "$host" "$cmd"
		echo -n '.'
		sleep 0.1
	done
}

for f in ${HOME}/bin/rcs/*\.sh; do
	. "${f}"
done

setxkbmap -option ctrl:nocaps
