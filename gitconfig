[diff]
	tool = vimdiff
[difftool]
	prompt = false
[push]
	default = simple
[core]
	editor = vim
[merge]
	tool = vimdiff
	conflictstyle = diff3
[mergetool]
	prompt = false
[alias]
	st = status
	df = difftool
	lo = log --oneline
[color]
	ui = auto
[branch]
	autosetuprebase = always
[pager]
       show = diff-so-fancy | less --tabs=8 -RFX
[tig]
	diff-highlight = true
[pull]
	rebase = true
