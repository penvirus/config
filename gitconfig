[alias]
	st = status
	df = difftool
	lo = log --oneline
[branch]
	autosetuprebase = always
[color]
	ui = auto
[core]
	editor = vim
[diff]
	tool = vimdiff
[difftool]
	prompt = false
[merge]
	tool = vimdiff
	conflictstyle = diff3
[mergetool]
	prompt = false
[pager]
	show = diff-so-fancy | less --tabs=8 -RFX
[pull]
	rebase = true
[push]
	default = simple
[tig]
	diff-highlight = true
	tab-size = 8
[user]
	name = Tzung-Bi Shih
	email = penvirus@gmail.com
[color "diff-highlight"]
	oldNormal = blue bold
	oldHighlight = blue bold 52
	newNormal = yellow bold
	newHighlight = yellow bold 22
[color "diff"]
	meta = yellow
	commit = white
	old = blue bold
	new = yellow bold
	whitespace = red reverse
